# Firebase Web アプリの設定値（Firebase コンソール → プロジェクト設定 → マイアプリ）
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# Vite では VITE_ プレフィックスの変数のみクライアントに公開されます。

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# 認証モード: 'password'（本番・メール+パスワードでログイン）/ 'anonymous'（開発・ログイン画面なし）
# 未設定時は安全側の 'password'。
VITE_AUTH_MODE=password
