{
  "name": "furusato-nozei-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "業務用 ふるさと納税 控除上限額シミュレーション (React + Firebase)",
  "scripts": {
    "dev": "vite",
